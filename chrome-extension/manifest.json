{
  "manifest_version": 3,
  "name": "YouTube Copilot",
  "version": "1.0",

  "permissions": ["activeTab"],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["sidebar.html"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}